# Database — Supabase PostgreSQL
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string → URI
# Use the "Transaction" or "Session" pooler (port 6543) for best serverless compatibility
# For quick local dev with SQLite: DATABASE_URL=sqlite+aiosqlite:///./kalakriti.db
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# AI — Google Gemini (free tier)
GOOGLE_API_KEY=


# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_FEE_PERCENT=10

# Storage — AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-south-1

# Storage — Cloudinary (alternative)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# App
APP_ENV=development
FRONTEND_URL=http://localhost:3000
